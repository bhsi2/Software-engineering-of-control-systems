{
    "require-dev": {
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5",
        "pestphp/pest": "^4.7",
        "mockery/mockery": "^1.6",
        "laravel/pail": "^1.2",
        "laravel/tinker": "^3.0",
        "larastan/larastan": "^3.9"
    },
    "scripts": {
        "format": "pint",
        "format:test": "pint --test",
        "analyse": "phpstan analyse",
        "test": "pest",
        "test:docker": "docker exec -it steam-app ./vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "laravel/framework": "^13.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    }
}
