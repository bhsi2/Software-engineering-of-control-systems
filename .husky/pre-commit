#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔄 Проверяем контейнер 'steam-app'..."
if ! docker ps --format '{{.Names}}' | grep -q 'steam-app'; then
    echo "🚀 Контейнер не запущен. Запускаем docker compose..."
    docker compose up -d steam-service
    sleep 5
fi

echo "📦 Устанавливаем Composer зависимости (включая dev)..."
docker exec steam-app composer install --dev --no-interaction

echo "🔥 Пересобираем автозагрузчик..."
docker exec steam-app composer dump-autoload

echo "🧹 Очищаем кэш Laravel..."
docker exec steam-app php artisan optimize:clear

echo "🎨 Запускаем форматирование кода..."
docker exec steam-app composer format

echo "🧪 Запускаем тесты..."
docker exec steam-app composer test

if [ $? -ne 0 ]; then
    echo "❌ Ошибка! Коммит отменён."
    exit 1
fi

echo "✅ Все проверки пройдены. Коммитим."