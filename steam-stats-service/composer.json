{
    "require-dev": {
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5",
        "pestphp/pest": "^4.7"
    }
    ,"scripts": {
        "format": "pint",
        "format:test": "pint --test",
        "analyse": "phpstan analyse --memory-limit=2G",
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
